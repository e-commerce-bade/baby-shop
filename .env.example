POSTGRES_DB=babyshop
POSTGRES_USER=babyshop_user
POSTGRES_PASSWORD=babyshop_password
POSTGRES_PORT=5432
DB_HOST=localhost
DB_PORT=5432
DB_NAME=babyshop
DB_USERNAME=babyshop_user
DB_PASSWORD=babyshop_password
PGHOST=localhost
PGPORT=5432
PGDATABASE=babyshop
PGUSER=babyshop_user
PGPASSWORD=babyshop_password
JDBC_DATABASE_URL=jdbc:postgresql://localhost:5432/babyshop
BACKEND_BASE_URL=http://localhost:5050
NEXT_PUBLIC_BACKEND_BASE_URL=http://localhost:5050
PRODUCT_UPLOAD_DIR=.uploads/products
SERVER_PORT=5050
# Mock odeme callback imza anahtari (yalnizca mock gateway kullanilirken gerekir)
MOCK_PAYMENT_CALLBACK_SECRET=

# Google OAuth client-id (Google ile giris kullanilacaksa doldurun)
GOOGLE_CLIENT_ID=

# Admin bootstrap: yalnizca ilk admin hesabini olusturmak icin gecici olarak true yapin.
# Uretimde kapali (false) tutun; acacaksaniz GUCLU bir parola verin.
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_ROLE=ADMIN
ADMIN_BOOTSTRAP_ENABLED=false

# JWT imzalama anahtari - ZORUNLU, en az 32 bayt. Ornek uretim:
#   openssl rand -base64 48
JWT_SECRET=
JWT_ACCESS_TOKEN_TTL_MINUTES=120
JWT_ISSUER=baby-shop-backend
